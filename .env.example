# === SLOTH Configuration ===
# "Chill 2 Kill"

# --- Elasticsearch ---
ES_VERSION=8.17.0
ES_HEAP=2g
ES_PORT=9200

# --- Kibana ---
KIBANA_PORT=5601

# --- Network ---
# Address the services listen on
# 0.0.0.0 = reachable from any IP (LAN, VPS)
# 127.0.0.1 = local only
BIND_ADDRESS=0.0.0.0

# Elasticsearch host (change if ES runs on another machine/VPS)
ES_HOST=localhost

# --- Pipeline ---
# Parallel workers for evidence processing.
# "auto" = 1 worker per GB of ES heap (e.g. 2g heap = 2 workers)
# Or set an explicit number: 1, 2, 3, etc.
PARALLEL_WORKERS=auto

# --- Data ---
DATA_PATH=./data
